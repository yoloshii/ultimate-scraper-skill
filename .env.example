# ultimate-scraper configuration
# Copy to .env and fill in values: cp .env.example .env
# Or export variables directly: export PROXY_HOST=your-proxy-host

# --- Proxy (optional — bring your own) ---
# Any HTTP/SOCKS5 proxy provider works. ProxyEmpire format shown as example.
# PROXY_HOST=                     # Proxy hostname (e.g., proxy.example.com)
# PROXY_PORT=                     # Proxy port (e.g., 5000)
# PROXY_USERNAME=                 # Proxy auth username
# PROXY_PASSWORD=                 # Proxy auth password

# --- AI Extraction (optional — 3-tier LLM routing) ---
# Tier 1: Local LLM (any OpenAI-compatible API)
# LOCAL_LLM_URL=                  # e.g., http://localhost:8080/v1/chat/completions
# LOCAL_LLM_ENABLED=false         # Set to true when local LLM is running

# Tier 2: z.ai GLM-4.5-Air (rate-limited fallback)
# ZAI_API_KEY=                    # z.ai API key

# Tier 3: Anthropic Claude Haiku (paid fallback)
# ANTHROPIC_API_KEY=              # Anthropic API key
# ANTHROPIC_BASE_URL=             # Default: https://api.anthropic.com

# --- CAPTCHA Solving (optional — pay-as-you-go) ---
# CAPSOLVER_API_KEY=              # CapSolver: fast AI solver (1-10s), ~$1-3/1000 solves
# TWOCAPTCHA_API_KEY=             # 2Captcha: human fallback (10-30s), broadest coverage

# --- CloakBrowser (Tier 2 stealth engine) ---
# CLOAKBROWSER_ENABLED=auto       # auto = use if installed, 1 = force, 0 = disable

# --- WebMCP (Chrome 146+ structured tool discovery) ---
# WEBMCP_ENABLED=auto             # auto = detect Chrome 146+, 1 = force, 0 = disable
# CHROME_CHANNEL=                 # chrome-dev, chrome-beta, chrome-canary, or empty
